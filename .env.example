# ========================================
# Database Configuration
# ========================================
# For local development: sqlite:///./database.db
# For PostgreSQL/Cloud: postgresql://user:password@host:port/dbname
# Example (Google Cloud SQL): postgresql://user:password@cloudsqlproxy-ip:5432/hrm_db
DATABASE_URL=sqlite:///./database.db

# ========================================
# Encryption & Security
# ========================================
# Generate a Fernet key using Python:
#   from cryptography.fernet import Fernet
#   key = Fernet.generate_key().decode()
#   print(key)
ENCRYPTION_KEY=your-fernet-key-here

# ========================================
# Web Push Notifications (VAPID)
# ========================================
# Generate VAPID keys using:
#   python -m py_vapid --gen --format string
# Returns: Public key and Private key
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here

# ========================================
# Cloudinary Configuration (Image/File Upload)
# ========================================
# Create account at https://cloudinary.com/
# Find credentials in Settings > API Environment variable
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ========================================
# Application Settings (Optional)
# ========================================
# FastAPI environment: development, staging, production
ENVIRONMENT=development

# Application host/port for local development
# (Typically managed by deployment platform in production)
HOST=0.0.0.0
PORT=8000
